{
  "name": "retent",
  "version": "0.1.0",
  "description": "The AI layer for software that will never get its own AI. Desktop overlay that learns application layouts through observation.",
  "main": "dist/main/main/index.js",
  "author": "Raabee Shamsi",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "ELECTRON_RUN_AS_NODE= electron dist/main/main/index.js",
    "package": "electron-builder",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "postinstall": "ELECTRON_RUN_AS_NODE= electron-rebuild"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "better-sqlite3": "^11.0.0",
    "electron-store": "^8.0.0",
    "keytar": "^7.9.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.33.0",
    "tesseract.js": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^36.9.5",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.retent.app",
    "productName": "Retent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "profiles/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
